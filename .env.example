# ============================================
# Core app settings
# ============================================

# Required: Postgres connection string
# Supabase example:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# Optional SSL mode for postgres driver:
# - require (recommended for Supabase)
# - disable (for local postgres without SSL)
DB_SSL=require

# Required in production. Used to sign JWT tokens.
JWT_SECRET=change-this-to-a-long-random-secret

# Backend server port
PORT=3000

# Runtime environment
NODE_ENV=development

# Optional: allow additional frontend origins, comma-separated
# Example:
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# ============================================
# AWS S3 upload support
# ============================================

AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BUCKET_NAME=

# Optional upload-related business variables used by the TS backend
FOLDER_NAME=
DOCUMENT_ID=
SUBSCRIPTION_TIER=FREE

# ============================================
# Existing Aliyun market API integration
# ============================================

ALIYUN_API_APP_KEY=
ALIYUN_API_APP_SECRET=
ALIYUN_API_APP_CODE=
ALIYUN_API_ENDPOINT=

# ============================================
# New market search / quote provider
# Fill these when you provide the Java-side API details
# ============================================

MARKET_API_BASE_URL=
MARKET_API_KEY=
MARKET_API_SECRET=
MARKET_API_APP_ID=
